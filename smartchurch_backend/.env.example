# Konfigurasi Keamanan Django
DEBUG=True
SECRET_KEY=isi_dengan_secret_key_django_kamu

# Django superuser (auto-created on first docker compose up)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=

# Konfigurasi Database PostgreSQL
DB_NAME=smartchurch_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432
OPENROUTER_API_KEY = 

AI_DB_USER = 
AI_DB_PASSWORD =

# Konfigurasi LangSmith Tracing
# Dapatkan API key dari: https://smith.langchain.com/settings
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=smartchurch-ai
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Base URL aplikasi untuk membangun URL media hasil generate AI
SERVER_PATH=http://localhost:8000

RTSP_URL=rtsp://user:pass@192.168.1.64:280/Streaming/Channels/101